# =====================================================================
# 占い自動収益化システム - 環境変数設定テンプレート
# このファイルを .env にコピーして各値を設定してください
# =====================================================================

# ─────────────────────────────────────────
# Gemini API（Google AI Studio）
# 取得先: https://aistudio.google.com/app/apikey
# 無料枠: 1500リクエスト/日
# ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────
# note.com 認証情報
# ※ 2段階認証は無効化してください
# ─────────────────────────────────────────
NOTE_EMAIL=your_note_email@example.com
NOTE_PASSWORD=your_note_password_here

# note のアカウントURL（X投稿でリンクとして使用）
NOTE_ACCOUNT_URL=https://note.com/your_username

# ─────────────────────────────────────────
# X（Twitter）API v2
# 取得先: https://developer.twitter.com/en/portal/dashboard
# Free Tier: 月1,500ツイート（本システムは約360/月なので十分）
# ─────────────────────────────────────────
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ─────────────────────────────────────────
# 週次noteのURL（週次ワークフロー実行後に自動更新される）
# 初期値として自分のnoteアカウントURLを設定
# ─────────────────────────────────────────
WEEKLY_NOTE_URL=https://note.com/your_username

# ─────────────────────────────────────────
# ログ設定
# ─────────────────────────────────────────
LOG_LEVEL=INFO
